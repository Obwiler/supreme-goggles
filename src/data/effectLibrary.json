{
  "conditions": [
    {
      "id": "cond_1",
      "name": "目标生命阈值",
      "desc": "当 {target} 的生命值 {compare} {value}% 时",
      "params": [
        {
          "key": "target",
          "label": "目标",
          "type": "select",
          "options": ["自己", "承接", "敌方单位", "友方单位"],
          "default": "自己"
        },
        {
          "key": "compare",
          "label": "比较",
          "type": "select",
          "options": ["低于", "高于", "等于"],
          "default": "低于"
        },
        {
          "key": "value",
          "label": "百分比",
          "type": "number",
          "min": 1,
          "max": 100,
          "default": 50
        }
      ]
    },
    {
      "id": "cond_2",
      "name": "目标拥有层数",
      "desc": "当 {target} 拥有 {stackName} 层数 {compare} {value} 时",
      "params": [
        {
          "key": "target",
          "label": "目标",
          "type": "select",
          "options": ["自己", "承接", "敌方单位", "友方单位"],
          "default": "自己"
        },
        {
          "key": "stackName",
          "label": "层数名称",
          "type": "string",
          "default": "增益"
        },
        {
          "key": "compare",
          "label": "比较",
          "type": "select",
          "options": ["大于", "小于", "等于"],
          "default": "大于"
        },
        {
          "key": "value",
          "label": "层数值",
          "type": "number",
          "min": 1,
          "max": 99,
          "default": 3
        }
      ]
    },
    {
      "id": "cond_3",
      "name": "随机概率",
      "desc": "有 {chance}% 的概率触发",
      "params": [
        {
          "key": "chance",
          "label": "概率",
          "type": "number",
          "min": 1,
          "max": 100,
          "default": 50
        }
      ]
    }
  ],
  "costs": [
